# --- Production Environment Variables ---

# IMPORTANT: Change this to a long, random, and secret string for production!
# You can generate one here: https://www.lastpass.com/features/password-generator
JWT_SECRET_KEY="your_super_secret_jwt_key_here"

# --- Production Database Connection Details ---
# Replace with your production database server details
DB_HOST="your_production_db_host" # e.g., localhost, or an IP address
DB_NAME="your_production_db_name"
DB_USER="your_production_db_user"
DB_PASS="your_production_db_password"

# --- Production SMTP Details ---
# Replace with your actual SMTP server details for sending emails
SMTP_HOST="your_smtp_host" # e.g., smtp.mailgun.org
SMTP_PORT="587"
SMTP_USER="your_smtp_username"
SMTP_PASS="your_smtp_password"
SMTP_SECURE="tls" # or 'ssl'
SMTP_FROM_EMAIL="your_from_email@yourdomain.com"
SMTP_FROM_NAME="Pragati Kurtis" # Your store's name

# --- Production Razorpay Keys ---
# IMPORTANT: Use your LIVE Razorpay keys for production
RAZORPAY_KEY_ID="your_live_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_live_razorpay_key_secret"
